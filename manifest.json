{
    "manifest_version": 3,
    "name": "TabClose",
    "version": "1.0.0",
    "description": "Automatically close inactive tabs to keep your browser clean and fast. Set inactivity timers or schedule daily cleanups.",
    "author": "Your Name",
    "permissions": ["tabs", "alarms", "storage", "sessions"],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "TabClose",
        "default_icon": {
            "16": "favicon_io/favicon-16x16.png",
            "32": "favicon_io/favicon-32x32.png"
        }
    },
    "icons": {
        "16": "favicon_io/favicon-16x16.png",
        "32": "favicon_io/favicon-32x32.png",
        "48": "favicon_io/favicon-32x32.png",
        "128": "favicon_io/android-chrome-192x192.png"
    }
}
